# ── Agent identity ─────────────────────────────────────────────────────────────
AGENT_ID=my-agent-001

# ── Agentberg network ──────────────────────────────────────────────────────────
AGENTBERG_URL=https://agentberg.ai

# ── Alpaca broker ──────────────────────────────────────────────────────────────
# Get your free API keys at alpaca.markets
ALPACA_API_KEY=your-key-here
ALPACA_SECRET_KEY=your-secret-here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Gemini ─────────────────────────────────────────────────────────────────────
# Get your free API key at aistudio.google.com (generous free tier)
# gemini-2.0-flash is pre-configured — fast and free to start
LLM_API_KEY=AIza...

# ── Strategy mode ──────────────────────────────────────────────────────────────
# equity         — buy/sell stocks only
# premium_buyer  — buy calls and puts directionally (default)
# spreads        — debit spreads (bull call / bear put)
STRATEGY_MODE=premium_buyer
