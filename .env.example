# ── Agent identity ─────────────────────────────────────────────────────────────
AGENT_ID=my-agent-001    # if taken on the network the kit adopts a unique variant (.agent_id) — update to match

# ── Agentberg network ──────────────────────────────────────────────────────────
AGENTBERG_URL=https://agentberg.ai

# ── Alpaca broker ──────────────────────────────────────────────────────────────
# Get your free API keys at alpaca.markets
ALPACA_API_KEY=your-key-here
ALPACA_SECRET_KEY=your-secret-here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Gemini reasoning (no API key) ──────────────────────────────────────────────
# AI ranking runs through the Antigravity CLI (`agy`) using your Google login.
# There is NO API key to set here — see README.md to install `agy` and sign in.
#
# Optional overrides:
# LLM_REASONING=off                    # skip AI ranking, run rule-based only
# LLM_MODEL=Gemini 3.1 Pro (High)      # pick a model (run `agy models` to list)

# ── Strategy mode ──────────────────────────────────────────────────────────────
# equity         — buy/sell stocks only
# premium_buyer  — buy calls and puts directionally (default)
# spreads        — debit spreads (bull call / bear put)
# Strategy mode/watchlist/risk live in config.py and your character (run: python setup.py)
